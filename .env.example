# Environment
ENVIRONMENT=development

# Server
PORT=8003

# Database Configuration
# For SQLite (development/testing):
AUTH_SERVICE__DB_URL=sqlite:///data/auth.db
# For PostgreSQL (production):
# AUTH_SERVICE__DB_URL=postgresql://auth_user:auth_password@localhost:5432/auth_db
# For PostgreSQL with asyncpg driver (recommended for async operations):
# AUTH_SERVICE__DB_URL=postgresql+asyncpg://auth_user:auth_password@localhost:5432/auth_db

# Redis
AUTH_SERVICE__REDIS_URL=redis://redis:6379/1

# JWT Settings
AUTH_SERVICE__JWT_ISSUER=https://auth.codelab.local
AUTH_SERVICE__JWT_AUDIENCE=codelab-api
AUTH_SERVICE__ACCESS_TOKEN_LIFETIME=900
AUTH_SERVICE__REFRESH_TOKEN_LIFETIME=2592000

# RSA Keys
AUTH_SERVICE__PRIVATE_KEY_PATH=/app/keys/private_key.pem
AUTH_SERVICE__PUBLIC_KEY_PATH=/app/keys/public_key.pem

# Security
# AUTH_SERVICE__MASTER_KEY=your-secure-password-here  # If not set, a random password will be generated and logged
AUTH_SERVICE__ENABLE_RATE_LIMITING=true
AUTH_SERVICE__RATE_LIMIT_PER_IP=5
AUTH_SERVICE__RATE_LIMIT_PER_USERNAME=10
AUTH_SERVICE__BRUTE_FORCE_THRESHOLD=5
AUTH_SERVICE__BRUTE_FORCE_LOCKOUT_DURATION=900

# Registration & Password Reset
AUTH_SERVICE__REGISTRATION_RATE_LIMIT=10
AUTH_SERVICE__REQUIRE_EMAIL_CONFIRMATION=true
AUTH_SERVICE__SUGGEST_USERNAMES=true
AUTH_SERVICE__AUDIT_LOG_RETENTION_DAYS=90
AUTH_SERVICE__PASSWORD_RESET_REQUEST_LIMIT=3
AUTH_SERVICE__PASSWORD_RESET_TOKEN_EXPIRATION_MINUTES=30

# Password Validation Rules
# Define password complexity requirements
AUTH_SERVICE__PASSWORD_MIN_LENGTH=8
AUTH_SERVICE__PASSWORD_MAX_LENGTH=128
AUTH_SERVICE__PASSWORD_REQUIRE_UPPERCASE=true
AUTH_SERVICE__PASSWORD_REQUIRE_LOWERCASE=true
AUTH_SERVICE__PASSWORD_REQUIRE_DIGITS=true
AUTH_SERVICE__PASSWORD_REQUIRE_SPECIAL_CHARS=true
# Pattern for special characters (regex)
AUTH_SERVICE__PASSWORD_SPECIAL_CHARS_PATTERN=[!@#$%^&*(),.?\":{}|<>]

# SMTP Configuration for Email
# For development (MailHog):
AUTH_SERVICE__SMTP_HOST=mailhog
AUTH_SERVICE__SMTP_PORT=1025
AUTH_SERVICE__SMTP_USERNAME=
AUTH_SERVICE__SMTP_PASSWORD=
AUTH_SERVICE__SMTP_FROM_EMAIL=noreply@codelab.local
AUTH_SERVICE__SMTP_USE_TLS=false

# For production (e.g., SendGrid, AWS SES, Mailgun):
# AUTH_SERVICE__SMTP_HOST=smtp.sendgrid.net
# AUTH_SERVICE__SMTP_PORT=587
# AUTH_SERVICE__SMTP_USERNAME=apikey
# AUTH_SERVICE__SMTP_PASSWORD=your-sendgrid-api-key
# AUTH_SERVICE__SMTP_FROM_EMAIL=noreply@yourdomain.com
# AUTH_SERVICE__SMTP_USE_TLS=true

AUTH_SERVICE__SMTP_TIMEOUT=30
AUTH_SERVICE__SMTP_MAX_RETRIES=3
AUTH_SERVICE__SEND_WELCOME_EMAIL=true
AUTH_SERVICE__SEND_PASSWORD_RESET_EMAIL=true
AUTH_SERVICE__REQUIRE_EMAIL_CONFIRMATION=true

# Swagger UI Configuration
# Enable or disable Swagger UI documentation endpoint at /docs
AUTH_SERVICE__ENABLE_SWAGGER_UI=true

# Logging
AUTH_SERVICE__LOG_LEVEL=DEBUG

# Token Blacklist Configuration
# Enable/disable token blacklist check
AUTH_SERVICE__USE_TOKEN_BLACKLIST=true
# Token revocation uses Redis with TTL equal to token's exp timestamp minus current time
# Minimum TTL to maintain tokens in blacklist (in seconds)
AUTH_SERVICE__TOKEN_BLACKLIST_MIN_TTL=3600

# Event Publisher Configuration (Redis Streams)
# Enable/disable event publishing to Redis Streams
AUTH_SERVICE__USE_EVENT_PUBLISHING=true
# Stream key for user events
AUTH_SERVICE__EVENTS_STREAM_KEY=user_events
# Maximum number of messages to keep in stream (MAXLEN)
AUTH_SERVICE__EVENTS_STREAM_MAXLEN=100000
# Event version for versioning changes
AUTH_SERVICE__EVENTS_VERSION=1.0
